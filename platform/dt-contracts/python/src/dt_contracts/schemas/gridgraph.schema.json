{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/dt-contracts/gridgraph.schema.json",
  "title": "GridGraphSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "t", "topology_hash", "topology_version", "nodes", "edges"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "t": { "type": "string", "minLength": 1 },
    "topology_hash": { "type": "string", "minLength": 1 },
    "topology_version": { "type": "integer", "minimum": 0 },
    "tick_count": { "type": "integer", "minimum": 0 },
    "metadata": { "type": "object", "additionalProperties": true },
    "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "items": { "$ref": "#/$defs/edge" } }
  },
  "$defs": {
    "kv": { "type": "object", "additionalProperties": true },
    "geoCoord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "altitude_m": { "type": "number" }
      }
    },
    "externalRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "object_type", "object_name"],
      "properties": {
        "engine": { "type": "string", "minLength": 1 },
        "object_type": { "type": "string", "minLength": 1 },
        "object_name": { "type": "string", "minLength": 1 },
        "terminal": { "type": ["string", "null"] },
        "phase": { "type": ["string", "null"] }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "static": { "$ref": "#/$defs/kv" },
        "dynamic": { "$ref": "#/$defs/kv" },
        "external_refs": { "type": "array", "items": { "$ref": "#/$defs/externalRef" } },
        "coordinates": { "oneOf": [{ "$ref": "#/$defs/geoCoord" }, { "type": "null" }] },
        "substation_id": { "type": ["string", "null"] },
        "zone": { "type": ["string", "null"] }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "source", "target"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "static": { "$ref": "#/$defs/kv" },
        "dynamic": { "$ref": "#/$defs/kv" },
        "external_refs": { "type": "array", "items": { "$ref": "#/$defs/externalRef" } }
      }
    }
  }
}
